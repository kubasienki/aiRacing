import socket
import struct

s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.connect(("localhost", 8081))
i = 1
while True:
  s.sendall(struct.pack("ffffff", 0.01, min(max(0.3, , 0.0, 0.0, 0.0, 0.0))
  data = s.recv(1024)
  unpacked = struct.unpack("fffffffffffff", data)
  print(unpacked)
  i+=1
